# 大模型 API 配置
# 复制此文件为 .env 并填入你的 API Key

# 默认模型: deepseek-chat / qwen-max / glm-4
VITE_DEFAULT_MODEL=deepseek-chat

# DeepSeek API Key (申请地址: https://platform.deepseek.com/)
VITE_DEEPSEEK_API_KEY=

# 通义千问 API Key (申请地址: https://dashscope.console.aliyun.com/)
VITE_QWEN_API_KEY=

# 智谱 GLM API Key (申请地址: https://open.bigmodel.cn/)
VITE_GLM_API_KEY=

# Kimi API Key (申请地址: https://platform.moonshot.cn/)
VITE_KIMI_API_KEY=
